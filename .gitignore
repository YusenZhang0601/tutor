# OS and Editor metadata
.DS_Store
**/.DS_Store
.vscode/
.idea/
*.suo
*.sln
*.bak
*.tmp
*.log

# Tool cache & python cache
.omc/
__pycache__/
*.pyc
.venv/
venv/
env/
ENV/

# Credentials & environment secrets
.env
.env.*
*.local
credentials.json
*.key

# Learner's personal workspace info, state & data
.tutor/config/learner-profile.md
.tutor/data/
state/

# Learner's personal study notes and directories (Keep only root INDEX.md)
subjects/**/*
!subjects/INDEX.md

# Learner's tutor self-evolution outputs (keep folder structures via .gitkeep)
.tutor/evolution/metrics.json
.tutor/evolution/observations.jsonl
.tutor/evolution/reflections/**/*
!.tutor/evolution/reflections/.gitkeep
.tutor/evolution/experiments/**/*
!.tutor/evolution/experiments/.gitkeep
.tutor/evolution/promoted/**/*
!.tutor/evolution/promoted/.gitkeep
